{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"defaultDuotone": false,
			"defaultGradients": false,
			"defaultPalette": false,
			"palette": [
				{ "color": "#0E0F12", "name": "Shemo Obsidian", "slug": "shemo-obsidian" },
				{ "color": "#1C1E22", "name": "Shemo Graphite", "slug": "shemo-graphite" },
				{ "color": "#23262B", "name": "Shemo Graphite 2", "slug": "shemo-graphite-2" },
				{ "color": "#F5F2EC", "name": "Shemo Ivory", "slug": "shemo-ivory" },
				{ "color": "#A7A39B", "name": "Shemo Muted", "slug": "shemo-muted" },
				{ "color": "#FF5A2C", "name": "Shemo Ember", "slug": "shemo-ember" }
			]
		},
		"layout": {
			"contentSize": "780px",
			"wideSize": "1180px"
		},
		"spacing": {
			"spacingSizes": [
				{ "name": "XS", "size": "0.5rem", "slug": "xs" },
				{ "name": "S", "size": "1rem", "slug": "s" },
				{ "name": "M", "size": "1.5rem", "slug": "m" },
				{ "name": "L", "size": "2rem", "slug": "l" },
				{ "name": "XL", "size": "3rem", "slug": "xl" },
				{ "name": "XXL", "size": "4.5rem", "slug": "xxl" }
			],
			"units": [ "%", "px", "em", "rem", "vh", "vw" ]
		},
		"typography": {
			"defaultFontSizes": false,
			"fontFamilies": [
				{
					"fontFamily": "Inter, 'Segoe UI', Arial, sans-serif",
					"name": "Shemo Body",
					"slug": "shemo-body"
				},
				{
					"fontFamily": "Fraunces, Georgia, serif",
					"name": "Shemo Display",
					"slug": "shemo-display"
				},
				{
					"fontFamily": "'Noto Kufi Arabic', 'Segoe UI', Tahoma, Arial, sans-serif",
					"name": "Shemo Arabic Body",
					"slug": "shemo-arabic-body"
				},
				{
					"fontFamily": "'Aref Ruqaa', 'Noto Kufi Arabic', serif",
					"name": "Shemo Arabic Display",
					"slug": "shemo-arabic-display"
				}
			],
			"fontSizes": [
				{ "name": "Small", "size": "0.875rem", "slug": "small" },
				{ "name": "Body", "size": "1rem", "slug": "body" },
				{ "name": "Lead", "size": "1.125rem", "slug": "lead" },
				{ "name": "Display S", "size": "2rem", "slug": "display-s" },
				{ "name": "Display M", "size": "3rem", "slug": "display-m" },
				{ "name": "Display L", "size": "4.5rem", "slug": "display-l" }
			]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--shemo-obsidian)",
			"text": "var(--wp--preset--color--shemo-ivory)"
		},
		"elements": {
			"button": {
				"border": { "radius": "6px" },
				"color": {
					"background": "var(--wp--preset--color--shemo-ember)",
					"text": "var(--wp--preset--color--shemo-obsidian)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--shemo-body)",
					"fontWeight": "800"
				}
			},
			"heading": {
				"color": { "text": "var(--wp--preset--color--shemo-ivory)" },
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--shemo-display)",
					"fontWeight": "800",
					"lineHeight": "1.04"
				}
			},
			"link": {
				"color": { "text": "var(--wp--preset--color--shemo-ember)" }
			}
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--shemo-body)",
			"fontSize": "var(--wp--preset--font-size--body)",
			"lineHeight": "1.65"
		}
	}
}
